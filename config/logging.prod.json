{
  "version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "json": {
      "()": "pythonjsonlogger.jsonlogger.JsonFormatter",
      "format": "%(asctime)s %(name)s %(levelname)s %(message)s",
      "json_default": "str"
    }
  },
  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "stream": "ext://sys.stdout",
      "formatter": "json"
    }
  },
  "root": {
    "level": "INFO",
    "handlers": ["console"]
  },
  "loggers": {
    "src": {
      "level": "INFO",
      "handlers": ["console"],
      "propagate": false
    },
    "uvicorn": {
      "level": "INFO",
      "handlers": ["console"],
      "propagate": false
    },
    "sqlalchemy": {
      "level": "WARNING",
      "handlers": ["console"],
      "propagate": false
    },
    "boto3": {
      "level": "WARNING",
      "handlers": ["console"],
      "propagate": false
    },
    "botocore": {
      "level": "WARNING",
      "handlers": ["console"],
      "propagate": false
    }
  }
}
