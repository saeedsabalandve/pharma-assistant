# ============================================================================
# Production-optimized multi-stage Docker build
# Includes security hardening, vulnerability scanning support,
# and AWS ECS/Fargate optimization
# ============================================================================

# ---------------------------------------------------------------------------
# Stage 1: Dependencies Builder
# ---------------------------------------------------------------------------
FROM python:3.11-slim-bookworm AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    POETRY_VERSION=1.7.1 \
    POETRY_HOME="/opt/poetry"

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    libpq-dev \
    libffi-dev \
    && rm -rf /var/lib/apt/lists/*

RUN curl -sSL https://install.python-poetry.org | python3 -
ENV PATH="${POETRY_HOME}/bin:${PATH}"

WORKDIR /app
COPY pyproject.toml poetry.lock ./
RUN poetry install --only main --no-root --no-ansi

# ---------------------------------------------------------------------------
# Stage 2: Security Scanner
# ---------------------------------------------------------------------------
FROM aquasec/trivy:latest AS scanner
COPY --from=builder /app /app
RUN trivy filesystem --severity HIGH,CRITICAL --no-progress /app

# ---------------------------------------------------------------------------
# Stage 3: Production Image
# ---------------------------------------------------------------------------
FROM python:3.11-slim-bookworm AS production

# Metadata labels
LABEL org.opencontainers.image.title="PharmaAssist" \
      org.opencontainers.image.description="AI-Powered Drug & Treatment Assistant" \
      org.opencontainers.image.version="1.0.0" \
      org.opencontainers.image.vendor="Your Organization" \
      org.opencontainers.image.licenses="MIT" \
      com.amazonaws.ecs.task-arn="" \
      com.amazonaws.ecs.container-name="pharma-assistant" \
      com.amazonaws.ecs.task-definition-family="pharma-assistant"

# Security: Create non-root user with specific UID/GID
RUN groupadd --system --gid 1001 pharma \
    && useradd --system --no-log-init --uid 1001 --gid pharma pharma

# Install only essential runtime packages
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    libssl3 \
    ca-certificates \
    curl \
    tini \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean \
    && rm -rf /tmp/* /var/tmp/*

# Security: Remove unnecessary packages and files
RUN find / -type f -name "*.pyc" -delete \
    && find / -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH="/app/.venv/bin:$PATH" \
    PYTHONPATH="/app" \
    APP_ENV="production" \
    LOG_LEVEL="INFO"

WORKDIR /app

# Copy application
COPY --from=builder /app/.venv /app/.venv
COPY src/ /app/src/
COPY alembic/ /app/alembic/
COPY alembic.ini config/ scripts/ /app/

# Copy and setup entrypoint
COPY scripts/entrypoint.sh /entrypoint.sh
RUN chmod 550 /entrypoint.sh

# Create necessary directories with strict permissions
RUN mkdir -p /var/log/pharma /var/run/pharma \
    && chown -R pharma:pharma /app /var/log/pharma /var/run/pharma \
    && chmod 750 /app /var/log/pharma /var/run/pharma

# Security: Set capabilities
USER pharma

# Health check with proper exit codes
HEALTHCHECK --interval=15s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -sf http://localhost:8000/health || exit 1

EXPOSE 8000

# Use tini as init system for proper signal handling
ENTRYPOINT ["/usr/bin/tini", "--", "/entrypoint.sh"]
CMD ["gunicorn", "src.main:app", "--config", "config/gunicorn.conf.py"]
