# ============================================
# PharmaAssist Environment Configuration
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env files with real secrets

# Application Environment
APP_NAME=pharma-assistant
APP_ENV=development
APP_VERSION=1.0.0
LOG_LEVEL=DEBUG
DEBUG=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_TIMEOUT=30
CORS_ORIGINS=["*"]

# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# PostgreSQL (RDS)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pharma_assistant
POSTGRES_USER=pharma_user
POSTGRES_PASSWORD=change_me_123!
POSTGRES_MIN_CONNECTIONS=5
POSTGRES_MAX_CONNECTIONS=20
POSTGRES_SSL_MODE=require

# MongoDB (DocumentDB)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=pharma_assistant
MONGODB_USER=pharma_user
MONGODB_PASSWORD=change_me_123!
MONGODB_MIN_POOL_SIZE=5
MONGODB_MAX_POOL_SIZE=20

# Redis (ElastiCache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_TIMEOUT=5

# OpenSearch
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_USE_SSL=false
OPENSEARCH_INDEX_PREFIX=pharma_assistant

# AWS Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-v2:1
BEDROCK_MAX_TOKENS=2000
BEDROCK_TEMPERATURE=0.7
BEDROCK_TOP_P=0.9

# AWS Comprehend Medical
COMPREHEND_MEDICAL_ENDPOINT=comprehendmedical.us-east-1.amazonaws.com

# SQS Queues
SQS_DRUG_INTERACTION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/pharma-drug-interactions
SQS_TREATMENT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789/pharma-treatments

# SNS Topics
SNS_ALERT_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:pharma-alerts
SNS_NOTIFICATION_TOPIC_ARN=arn:aws:sns:us-east-1:123456789:pharma-notifications

# S3 Buckets
S3_MODELS_BUCKET=pharma-assistant-models-dev
S3_LOGS_BUCKET=pharma-assistant-logs-dev

# Security
JWT_SECRET_KEY=your_jwt_secret_key_change_me
JWT_ALGORITHM=RS256
JWT_EXPIRATION_MINUTES=60
ENCRYPTION_KEY_ARN=arn:aws:kms:us-east-1:123456789:key/your-key-id

# Cache Configuration
CACHE_TTL_DEFAULT=300
CACHE_TTL_DRUG_INFO=3600
CACHE_TTL_TREATMENT=1800
CACHE_TTL_INTERACTION=900

# Rate Limiting
RATE_LIMIT_PER_SECOND=100
RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_BURST=200

# Monitoring
CLOUDWATCH_NAMESPACE=PharmaAssist
ENABLE_XRAY=true
XRAY_SAMPLING_RATE=0.1
METRICS_ENABLED=true

# Feature Flags
ENABLE_RAG_ENHANCEMENT=true
ENABLE_REAL_TIME_ALERTS=true
ENABLE_AUDIT_LOGGING=true
ENABLE_PHI_DETECTION=true
